---
import Navbar from '../components/Navbar.astro';
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>

  <body
    class="bg-[#050816] text-zinc-100 min-h-screen antialiased overflow-x-hidden"
  >

    <div
      class="fixed inset-0 -z-10"
    >

      <div
        class="absolute top-[-200px] left-1/2 -translate-x-1/2 w-[900px] h-[900px] bg-green-500/10 blur-[180px] rounded-full"
      ></div>

      <div
        class="absolute bottom-[-300px] right-[-200px] w-[700px] h-[700px] bg-emerald-500/5 blur-[180px] rounded-full"
      ></div>

    </div>

    <Navbar />

    <slot />

  </body>
</html>
