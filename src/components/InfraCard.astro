---
interface Props {
  title: string;
  type: string;
  description: string;
}

const { title, type, description } = Astro.props;
---

<div
  class="rounded-2xl border border-zinc-800 bg-zinc-900/40 p-6 backdrop-blur-sm hover:border-green-500/40 transition-all duration-300"
>

  <div
    class="flex items-center justify-between"
  >

    <h3
      class="text-xl font-semibold text-zinc-100"
    >
      {title}
    </h3>

    <span
      class="text-xs uppercase tracking-wide text-green-400 bg-green-500/10 px-3 py-1 rounded-full"
    >
      {type}
    </span>

  </div>

  <p
    class="mt-4 text-zinc-400 leading-relaxed"
  >
    {description}
  </p>

</div>
