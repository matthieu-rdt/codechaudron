---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<div
  class="rounded-2xl border border-zinc-800 bg-zinc-900/40 p-6 backdrop-blur-sm hover:border-green-500/40 transition-all duration-300"
>

  <h3
    class="text-xl font-semibold text-green-400"
  >
    {title}
  </h3>

  <p
    class="mt-3 text-zinc-400 leading-relaxed"
  >
    {description}
  </p>

</div>
