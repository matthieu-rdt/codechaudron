---
import Layout from '../layouts/Layout.astro';
import StackCard from '../components/StackCard.astro';
import InfraCard from '../components/InfraCard.astro';
---

<Layout title="Code Chaudron">

  <main>

    <section
      class="min-h-screen flex flex-col items-center justify-center px-6 pt-10 text-center max-w-5xl mx-auto"
    >

      <h1
        class="text-5xl md:text-7xl font-bold tracking-tight text-green-500 leading-none"
      >
        Code Chaudron
      </h1>

      <p
        class="mt-10 text-xl md:text-2xl text-zinc-200 font-light"
      >
        Infrastructure, automation & self-hosting experiments.
      </p>

      <p
        class="mt-8 text-lg text-zinc-500 max-w-2xl mx-auto leading-relaxed"
      >
        Suivez mon apprentissage autour du DevOps,
        de l’automatisation et des infrastructures modernes.
      </p>

      <div
        class="mt-14 flex items-center justify-center gap-6 flex-wrap"
      >

        <a
          href="https://github.com"
          target="_blank"
          class="px-8 py-4 rounded-2xl bg-green-500 text-black text-xl font-semibold hover:bg-green-400 transition-all duration-200"
        >
          GitHub
        </a>

        <a
          href="/roadmap"
          class="px-8 py-4 rounded-2xl border border-zinc-700 text-zinc-200 text-xl hover:border-green-500 hover:text-green-400 transition-all duration-200"
        >
          Voir la roadmap
        </a>

      </div>

    </section>

    <section
      class="max-w-6xl mx-auto px-6 pb-24"
    >

      <div
        class="text-center mb-14"
      >

        <h2
          class="text-4xl font-bold text-zinc-100"
        >
          Current Stack
        </h2>

        <p
          class="mt-4 text-zinc-500 text-lg"
        >
          Technologies currently deployed and tested in my infrastructure.
        </p>

      </div>

      <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
      >

        <StackCard
          title="Docker"
          description="Containerized deployment and service orchestration."
        />

        <StackCard
          title="Traefik"
          description="Reverse proxy with automatic HTTPS and routing."
        />

        <StackCard
          title="Ansible"
          description="Infrastructure automation and configuration management."
        />

        <StackCard
          title="WireGuard"
          description="Secure remote access to private infrastructure."
        />

        <StackCard
          title="PostgreSQL"
          description="Database services for self-hosted applications."
        />

        <StackCard
          title="Restic"
          description="Encrypted backup management and restore workflows."
        />

      </div>

    </section>

    <section
      class="max-w-6xl mx-auto px-6 pb-32"
    >

      <div
        class="text-center mb-14"
      >

        <h2
          class="text-4xl font-bold text-zinc-100"
        >
          Infrastructure Overview
        </h2>

        <p
          class="mt-4 text-zinc-500 text-lg"
        >
          Public and private services currently running in my homelab environment.
        </p>

      </div>

      <div
        class="grid grid-cols-1 lg:grid-cols-2 gap-6"
      >

        <InfraCard
          title="OVH VPS"
          type="PUBLIC"
          description="Main public-facing infrastructure hosting reverse proxy and services."
        />

        <InfraCard
          title="Traefik"
          type="PROXY"
          description="Automatic HTTPS, routing and secure entrypoint management."
        />

        <InfraCard
          title="WireGuard"
          type="PRIVATE"
          description="Secure private access to internal administration services."
        />

        <InfraCard
          title="Portainer"
          type="INTERNAL"
          description="Container management interface protected behind VPN access."
        />

      </div>

    </section>

  </main>

</Layout>
