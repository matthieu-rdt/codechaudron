---
import Layout from '../layouts/Layout.astro';
import StackCard from '../components/StackCard.astro';
import InfraCard from '../components/InfraCard.astro';
---

<Layout title="Code Chaudron">

  <main>

    <section
      class="min-h-screen flex flex-col items-center justify-center px-6 pt-10 text-center max-w-5xl mx-auto"
    >

      <h1
        class="text-5xl md:text-7xl font-bold tracking-tight text-green-500 leading-none"
      >
        Code Chaudron
      </h1>

      <p
        class="mt-10 text-xl md:text-2xl text-zinc-200 font-light"
      >
        Expérimentations en infrastructure, automatisation et auto-hébergement.
      </p>

      <p
        class="mt-8 text-lg text-zinc-500 max-w-2xl mx-auto leading-relaxed"
      >
        Suivez mon apprentissage autour du DevOps,
        de l’automatisation et des infrastructures modernes.
      </p>

      <div
        class="mt-14 flex items-center justify-center gap-6 flex-wrap"
      >

        <a
          href="https://github.com"
          target="_blank"
          class="px-8 py-4 rounded-2xl bg-green-500 text-black text-xl font-semibold hover:bg-green-400 transition-all duration-200"
        >
          GitHub
        </a>

        <a
          href="/roadmap"
          class="px-8 py-4 rounded-2xl border border-zinc-700 text-zinc-200 text-xl hover:border-green-500 hover:text-green-400 transition-all duration-200"
        >
          Voir la roadmap
        </a>

      </div>

    </section>

    <section
      class="max-w-6xl mx-auto px-6 pb-24"
    >

      <div
        class="text-center mb-14"
      >

        <h2
          class="text-4xl font-bold text-zinc-100"
        >
          Technologies actuelles
        </h2>

        <p
          class="mt-4 text-zinc-500 text-lg"
        >
          Technologies actuellement déployées et testées dans mon infrastructure.
        </p>

      </div>

      <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
      >

        <StackCard
          title="Docker"
          description="Déploiement conteneurisé et orchestration de services."
        />

        <StackCard
          title="Traefik"
          description="Proxy inverse avec HTTPS automatique et routage applicatif."
        />

        <StackCard
          title="Ansible"
          description="Automatisation d’infrastructure et gestion de configuration."
        />

        <StackCard
          title="WireGuard"
          description="Accès distant sécurisé à l’infrastructure privée."
        />

        <StackCard
          title="PostgreSQL"
          description="Services de base de données pour applications auto-hébergées."
        />

        <StackCard
          title="Restic"
          description="Gestion de sauvegardes chiffrées et processus de restauration."
        />

      </div>

    </section>

    <section
      class="max-w-6xl mx-auto px-6 pb-32"
    >

      <div
        class="text-center mb-14"
      >

        <h2
          class="text-4xl font-bold text-zinc-100"
        >
          Vue d’ensemble de l’infrastructure
        </h2>

        <p
          class="mt-4 text-zinc-500 text-lg"
        >
          Services publics et privés actuellement exécutés dans mon environnement homelab.
        </p>

      </div>

      <div
        class="grid grid-cols-1 lg:grid-cols-2 gap-6"
      >

        <InfraCard
          title="OVH VPS"
          type="PUBLIC"
          description="Infrastructure principale exposée publiquement, hébergeant le proxy inverse et les services."
        />

        <InfraCard
          title="Traefik"
          type="PROXY"
          description="HTTPS automatique, routage et gestion sécurisée des points d’entrée."
        />

        <InfraCard
          title="WireGuard"
          type="PRIVÉ"
          description="Accès privé sécurisé aux services internes d’administration."
        />

        <InfraCard
          title="Portainer"
          type="INTERNE"
          description="Interface de gestion des conteneurs protégée derrière un accès VPN."
        />

      </div>

    </section>

  </main>

</Layout>
